{
  "name": "markdown",
  "version": "0.1.0",
  "description": "Markdown renderer + CLI (md -> HTML) with optional local preview server",
  "license": "MIT",
  "type": "module",
  "bin": {
    "markdown": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --watch dist/cli.js --help",
    "test": "vitest run",
    "lint": "node -e \"console.log('Add eslint if you want')\"",
    "prepublishOnly": "npm run test && npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "express": "^4.19.2",
    "highlight.js": "^11.10.0",
    "markdown-it": "^14.1.0",
    "sanitize-html": "^2.13.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/sanitize-html": "^2.13.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
